# ===== 必填 =====
# GitHub Token（用于 API 调用，提高速率限制）
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# AI 摘要服务（至少选一个）
# Anthropic 兼容接口（支持 DeepSeek 等中转）
CLAUDE_API_KEY=sk-xxxxxxxxxxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1     # 官方
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic  # DeepSeek 中转（国内推荐）
AI_MODEL=deepseek-v4-pro[1m]
# 或者用 OpenAI 兼容接口
# OPENAI_API_KEY=sk-xxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# ===== 推送渠道（至少选一个） =====

# 邮件推送（SMTP）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_password
TO_EMAIL=receiver@qq.com

# 微信推送（PushPlus，推荐）
# 注册获取 token: https://www.pushplus.plus/
PUSHPLUS_TOKEN=xxxxxxxxxxxx

# ===== 可选 =====
# 自定义 AI 模型（默认 claude-sonnet-4-6）
# AI_MODEL=claude-sonnet-4-6

# 简报语言（默认 zh）
# BRIEFING_LANG=zh
